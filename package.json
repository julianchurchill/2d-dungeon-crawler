{
  "name": "dungeon-crawler",
  "version": "0.9.4",
  "type": "module",
  "scripts": {
    "predev": "node scripts/gen-build-info.js",
    "dev": "vite --host",
    "prebuild": "node scripts/gen-build-info.js",
    "build": "vite build",
    "preview": "vite preview",
    "pretest": "node scripts/gen-build-info.js",
    "test": "NODE_OPTIONS='--loader ./features/support/phaser-loader.mjs --no-warnings' cucumber-js --format progress-bar",
    "test:pretty": "NODE_OPTIONS='--loader ./features/support/phaser-loader.mjs --no-warnings' cucumber-js --format pretty --format-options '{\"colorsEnabled\":true}'",
    "test:html": "NODE_OPTIONS='--loader ./features/support/phaser-loader.mjs --no-warnings' cucumber-js --format html:cucumber-report.html",
    "prepare-release": "node scripts/prepare-release.js",
    "tag-release": "node scripts/tag-release.js"
  },
  "dependencies": {
    "phaser": "^3.60.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "vite": "^4.5.0"
  }
}
